# API Configuration
# Copy this file to .env and fill in your values

# API Host (for proxy configuration)
VITE_API_HOST=your_api_host
VITE_API_PORT=8000
VITE_API_PY_PORT=8001

# Laravel Backend API URL (leave empty to use Vite proxy in development)
VITE_API_BASE_URL=

# Image Base URL (leave empty to use Vite proxy in development)
VITE_IMAGE_BASE_URL=

# AMap Configuration (for map features)
VITE_AMAP_JS_KEY=your_amap_js_key_here
VITE_AMAP_SECURITY_CODE=your_amap_security_code_here
